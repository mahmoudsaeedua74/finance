# --- Auth (NextAuth) — required in production; required for any login beyond first-time dev seed
# Create a long random string, e.g. `openssl rand -base64 32`
AUTH_SECRET=
# On Vercel, set the site URL (local dev: http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000
# You can also create a user: npm run create-user -- you@email.com yourpassword
#
# Required: MongoDB connection string (local or Atlas)
# Local: mongodb://127.0.0.1:27017/personal-finance
# Atlas: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/personal-finance?retryWrites=true&w=majority
# If your Atlas URI is ...mongodb.net/?appName=... (no database in the path), this app uses db name:
MONGODB_URI=
# MONGODB_DB=personal-finance

# If you see: querySrv ECONNREFUSED _mongodb._tcp...  →  bad DNS/ISP. This project sets
# Google/Cloudflare DNS in Node (see src/lib/mongodb.ts). To disable: MONGODB_SKIP_FIX_DNS=1
# Or in Atlas, use a "standard" mongodb:// host list (not +srv) from Connect.

# Optional: public URL of the app (e.g. for future absolute links)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# EMAIL — pick ONE provider (Resend recommended on Vercel free tier)
# =============================================================================
#
# Option A: Resend (free ~3,000 emails/month) — https://resend.com
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="Finance <onboarding@resend.dev>"
#   ↑ onboarding@resend.dev works for testing to your own verified email only.
#   For production, verify your domain in Resend and use e.g. noreply@yourdomain.com
#
# Option B: SMTP (Gmail app password, Brevo, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=16-char-app-password
# SMTP_FROM="Finance <you@gmail.com>"
#
# Optional: brand name in HTML + subject line
# EMAIL_APP_NAME=Personal Finance
#
# Email TLS: on localhost, SMTP cert checks are relaxed in development by default.
# SMTP_TLS_STRICT=1  → force verification in dev
# SMTP_TLS_INSECURE=1 → relax in production (not recommended)

# =============================================================================
# SCHEDULED JOBS (daily login reminder, digest, recurring due, monthly closing)
# =============================================================================
#
# On Vercel Hobby: vercel.json defines crons that call /api/jobs/daily and /api/jobs/monthly.
# Vercel automatically sets CRON_SECRET and sends Authorization: Bearer <CRON_SECRET>.
# You can also set JOBS_SECRET for manual curl / external schedulers (cron-job.org).
#
# JOBS_SECRET=change-me-long-random-string
#
# Login reminder window (Africa/Cairo default):
# LOGIN_REMINDER_TIMEZONE=Africa/Cairo
# LOGIN_REMINDER_START_HOUR=10
# LOGIN_REMINDER_END_HOUR=23
#
# Manual test (local):
# curl -X POST http://localhost:3000/api/jobs/daily -H "x-jobs-secret: YOUR_JOBS_SECRET"
